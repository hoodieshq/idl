# Per-cluster RPC URLs used by the API routes. Each cluster falls back to its
# own variable only; missing a variable yields a clear 500 for that cluster.
# Testnet is not supported (Program Metadata is not deployed there).
RPC_MAINNET=https://api.mainnet-beta.solana.com
RPC_DEVNET=https://api.devnet.solana.com

# Legacy: if set, used as a fallback for the `mainnet-beta` cluster only.
# RPC_URL=https://api.mainnet-beta.solana.com
